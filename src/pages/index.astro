---
import Layout from '../layouts/Layout.astro';
import { getSortedPosts, SITE, dateWithWeekday } from '../posts';

const allPosts = await getSortedPosts();
const RECENT = 30;
const posts = allPosts.slice(0, RECENT);
const hasMore = allPosts.length > RECENT;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'AI Daily Insights',
  alternateName: 'AI 日报',
  url: SITE,
  description: 'AI Daily Insights — 每日 AI 资讯，为人与 Agent 而生',
  inLanguage: 'zh-CN',
  publisher: { '@type': 'Organization', name: 'AI Daily Insights', url: SITE },
};
---

<Layout jsonLd={jsonLd}>
  <section class="hero">
    <h1 class="brand">AI Daily Insights<span class="cursor"></span></h1>
    <p class="slogan">每日 AI 资讯 · 为人与 Agent 而生</p>
    <div class="bootline"><span class="dotk"></span>system ready · {allPosts.length} entries indexed · last sync {posts[0].data.date} · booted in 0.08s</div>
  </section>

  <hr class="rule" />

  <div class="cmd"><span class="pr">$</span>ls ./news <span class="flag">--sort=date</span></div>
  <div class="listhdr"><span>date</span><span>./news/*.md &nbsp; ({allPosts.length} entries)</span></div>

  {posts.map((post) => (
    <a class="news-row" href={`/${post.id}/`}>
      <div class="news-date">{dateWithWeekday(post.data.date)}</div>
      <div>
        <div class="nt">{post.data.title}</div>
        <div class="ns">{post.data.summary}</div>
      </div>
      <div class="stat">[parsed]</div>
    </a>
  ))}

  {hasMore && (
    <a class="more-row" href="/archive/">
      <span class="pr">$</span>ls ./news --all<span class="more-x"> · 查看全部 {allPosts.length} 期 →</span>
    </a>
  )}

  <section class="usebar">
    <div class="use-label">// 怎么用 — 三种入口，按你是谁选一个</div>
    <div class="use-row">
      <span class="use-k">📱 看资讯</span>
      <span class="use-d">直接打开本站 <a href="/">www.aidailyinsights.cn</a>，或订阅 <a href="/feed.xml">RSS</a>。</span>
    </div>
    <div class="use-row">
      <span class="use-k">⌨️ 终端速览</span>
      <span class="use-d"><code>npx ai-daily-insights latest</code> — 一行命令在终端看当天资讯。</span>
    </div>
    <div class="use-row">
      <span class="use-k">🤖 让 AI 调用</span>
      <span class="use-d"><code>claude mcp add ai-daily-insights -- npx -y ai-daily-insights-mcp</code> — 装进 Claude / Cursor。<a href="/qa/">详细说明 →</a></span>
    </div>
  </section>

  <section class="agentbar">
    <div class="agent-label">// 给 AI / Agent 的接口 — machine-readable endpoints</div>
    <div class="agent-links">
      <a class="chip" href="/llms.txt"><span class="dotk"></span>llms.txt</a>
      <a class="chip" href="/feed.xml"><span class="dotk"></span>RSS</a>
      <a class="chip" href="/index.json"><span class="dotk"></span>index.json</a>
      <a class="chip" href="/qa/"><span class="dotk"></span>Q&A</a>
    </div>
  </section>
</Layout>
