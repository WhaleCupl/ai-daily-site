---
import { render } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import { getSortedPosts } from '../posts';

export async function getStaticPaths() {
  const posts = await getSortedPosts();
  return posts.map((post) => ({ params: { slug: post.id }, props: { post } }));
}

const { post } = Astro.props;
const { date, title, summary, tags } = post.data;
const { Content, headings } = await render(post);

const navItems = headings
  .filter((h) => h.depth === 2)
  .map((h) => ({ id: h.slug, title: h.text.replace(/^❯\s*/, '').trim() }));
---

<Layout title={`${title} · AI Daily Insights`} description={summary}>
  <a class="backnav" href="/">
    <span class="back-arrow">←</span>
    <span class="back-label">返回 AI Daily 首页</span>
    <span class="back-cmd">cd ~/news</span>
  </a>

  <div class="md article-head">
    <div class="meta">
      <span>{date}</span>
      {tags.map((tag) => (
        <>
          <span class="sep">·</span>
          <span class="tag">#{tag}</span>
        </>
      ))}
      <span class="sep">·</span>
      <span class="st">status: parsed</span>
    </div>
  </div>

  {navItems.length > 1 && (
    <nav class="article-index" aria-label="今日新闻导航">
      <div class="cmd"><span class="pr">&gt;</span>tree ./today <span class="flag">--depth=1</span></div>
      <ol>
        {navItems.map((item, index) => (
          <li>
            <a href={`#${item.id}`}>
              <span>{String(index + 1).padStart(2, '0')}</span>
              {item.title}
            </a>
          </li>
        ))}
      </ol>
      <div class="index-status">// AI Daily index · output: reading_queue · status: ready</div>
    </nav>
  )}

  <article class="md">
    <Content />
  </article>
</Layout>
