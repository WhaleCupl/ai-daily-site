---
import { render } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import { getSortedPosts, SITE, ORG_JSONLD, dateWithWeekday, tagUrl } from '../posts';

export async function getStaticPaths() {
  const posts = await getSortedPosts();
  return posts.map((post) => ({ params: { slug: post.id }, props: { post } }));
}

const { post } = Astro.props;
const { date, title, summary, tags, image, summary_en } = post.data;
const { Content, headings } = await render(post);

const articleUrl = `${SITE}/${post.id}/`;
const navItems = headings
  .filter((h) => h.depth === 2)
  .map((h) => ({ id: h.slug, title: h.text.replace(/^❯\s*/, '').trim() }));
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'NewsArticle',
  headline: title,
  description: summary,
  datePublished: date,
  dateModified: date,
  inLanguage: 'zh-CN',
  url: articleUrl,
  mainEntityOfPage: { '@type': 'WebPage', '@id': articleUrl },
  keywords: tags.join(', '),
  ...(image ? { image: new URL(image, SITE).href } : {}),
  ...(summary_en ? { abstract: summary_en } : {}),
  author: ORG_JSONLD,
  publisher: ORG_JSONLD,
  // 每条新闻作为可寻址的子条目暴露给搜索引擎（锚点级）。
  hasPart: navItems.map((item, i) => ({
    '@type': 'NewsArticle',
    position: i + 1,
    headline: item.title,
    url: `${articleUrl}#${item.id}`,
    datePublished: date,
    inLanguage: 'zh-CN',
    isPartOf: { '@type': 'NewsArticle', '@id': articleUrl },
    publisher: ORG_JSONLD,
  })),
};
---

<Layout
  title={`${title} · AI Daily Insights`}
  description={summary}
  type="article"
  publishedTime={date}
  image={image}
  jsonLd={jsonLd}
>
  <a class="backnav" href="/">
    <span class="back-arrow">←</span>
    <span class="back-label">返回 AI Daily 首页</span>
  </a>

  <div class="md article-head">
    <div class="meta">
      <span>{dateWithWeekday(date)}</span>
      {tags.map((tag) => (
        <>
          <span class="sep">·</span>
          <a class="tag" href={tagUrl(tag)}>#{tag}</a>
        </>
      ))}
    </div>
  </div>

  {navItems.length > 1 && (
    <nav class="article-index" aria-label="今日新闻导航">
      <div class="cmd">本期目录</div>
      <ol>
        {navItems.map((item, index) => (
          <li>
            <a href={`#${item.id}`}>
              <span>{String(index + 1).padStart(2, '0')}</span>
              {item.title}
            </a>
          </li>
        ))}
      </ol>
      <div class="index-status">共 {headings.length} 条</div>
    </nav>
  )}

  <article class="md">
    <Content />
  </article>
</Layout>
