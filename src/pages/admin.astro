---
import Layout from '../layouts/Layout.astro';
---

<Layout title="发布后台 · AI Daily Insights" description="内容发布后台" noindex>
  <a class="backnav" href="/">
    <span class="back-arrow">←</span>
    <span class="back-label">返回 AI Daily 首页</span>
    <span class="back-cmd">cd ~/news</span>
  </a>
  <div class="cmd"><span class="pr">$</span>upload ./today.md <span class="flag">--publish</span></div>

  <article class="md">
    <h1>❯ 发布后台</h1>

    <h2>❯ 数据统计</h2>
    <p class="admin-hint">网页 = 人打开页面的次数；接口/MCP = <code>/index.json</code>、<code>/&lt;日期&gt;.json</code>、<code>/feed.xml</code> 这些被 MCP / CLI / RSS 阅读器调用的次数。是原始命中数，不做去重，仅供看趋势。</p>
    <div id="stats-totals" class="admin-stats-grid">
      <div class="admin-hint">加载中…</div>
    </div>
    <div id="stats-daily" class="admin-list"></div>

    <h2>❯ 部署状态</h2>
    <p class="admin-hint">每次发布 / 编辑 / 删除都会提交到仓库并触发一次构建部署。若某次显示「失败」，多半是 frontmatter 格式有误——线上不会更新，修好后重新保存即可。</p>
    <div id="deploys" class="admin-list">
      <p class="admin-hint">加载中…</p>
    </div>

    <h2>❯ 发布新一期</h2>
    <p>
      选择 <code>.md</code> 文件直接发布，文件名随意。上线日期按「内容 frontmatter 的
      <code>date</code> → 文件名里的日期 → 当天」自动决定。两种格式都支持：带
      <code>date</code> / <code>title</code> / <code>summary</code> / <code>tags</code> frontmatter 的标准文件，
      或微信/CLI 终端风文件（无 frontmatter，后台会自动剥掉 <code>tree</code>/<code>cat</code> 外壳、把 <code>#标签</code>
      转成 tags、取头条标题与 signal 生成 frontmatter）。
    </p>
    <p>发布后会自动提交到仓库并触发部署，约 1 分钟后线上生效，整个过程不需要再碰终端。</p>

    <form id="publish-form">
      <input type="file" id="file-input" name="file" accept=".md" required />
      <button type="submit" id="submit-btn">发布</button>
    </form>
    <div id="status" class="admin-status"></div>

    <h2>❯ 已发布文章</h2>
    <div id="article-list" class="admin-list">
      <p class="admin-hint">加载中…</p>
    </div>

    <div id="editor-wrap" class="admin-editor" hidden>
      <h2><span id="editor-title">❯ 编辑</span></h2>

      <div class="admin-fields">
        <label class="admin-field">
          <span class="admin-field-label">标题</span>
          <input type="text" id="f-title" />
        </label>
        <label class="admin-field">
          <span class="admin-field-label">摘要</span>
          <textarea id="f-summary" rows="2"></textarea>
        </label>
        <label class="admin-field">
          <span class="admin-field-label">标签</span>
          <input type="text" id="f-tags" placeholder="用逗号分隔，如 OpenAI, 融资, 芯片" />
        </label>
        <label class="admin-field">
          <span class="admin-field-label">来源 <span class="admin-field-opt">可选</span></span>
          <input type="text" id="f-source" />
        </label>
      </div>

      <div class="admin-bodybar">
        <span class="admin-field-label">正文（Markdown）</span>
        <button type="button" id="editor-preview-toggle" class="admin-btn-link">预览</button>
      </div>
      <textarea id="editor-textarea" rows="20"></textarea>
      <div id="editor-preview" class="md admin-preview" hidden></div>

      <div class="admin-editor-actions">
        <button type="button" id="editor-save">保存修改</button>
        <button type="button" id="editor-cancel" class="admin-btn-secondary">取消</button>
      </div>
      <div id="editor-status" class="admin-status"></div>
    </div>
  </article>

  <script>
    import yaml from 'js-yaml';

    const publishForm = document.getElementById('publish-form') as HTMLFormElement;
    const status = document.getElementById('status') as HTMLDivElement;
    const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
    const fileInput = document.getElementById('file-input') as HTMLInputElement;

    const listEl = document.getElementById('article-list') as HTMLDivElement;
    const editorWrap = document.getElementById('editor-wrap') as HTMLDivElement;
    const editorTitle = document.getElementById('editor-title') as HTMLSpanElement;
    const editorTextarea = document.getElementById('editor-textarea') as HTMLTextAreaElement;
    const editorStatus = document.getElementById('editor-status') as HTMLDivElement;
    const editorSaveBtn = document.getElementById('editor-save') as HTMLButtonElement;
    const editorCancelBtn = document.getElementById('editor-cancel') as HTMLButtonElement;

    const fTitle = document.getElementById('f-title') as HTMLInputElement;
    const fSummary = document.getElementById('f-summary') as HTMLTextAreaElement;
    const fTags = document.getElementById('f-tags') as HTMLInputElement;
    const fSource = document.getElementById('f-source') as HTMLInputElement;
    const previewToggle = document.getElementById('editor-preview-toggle') as HTMLButtonElement;
    const previewEl = document.getElementById('editor-preview') as HTMLDivElement;

    // 原文里 frontmatter 之外、schema 未覆盖的额外字段，编辑时原样保留，保存时写回。
    let extraFrontmatter: Record<string, unknown> = {};

    const statsTotalsEl = document.getElementById('stats-totals') as HTMLDivElement;
    const statsDailyEl = document.getElementById('stats-daily') as HTMLDivElement;

    const deploysEl = document.getElementById('deploys') as HTMLDivElement;

    let editingDate: string | null = null;

    const WEEKDAYS = ['星期日', '星期一', '星期二', '星期三', '星期四', '星期五', '星期六'];
    function dateWithWeekday(date: string): string {
      const m = /^(\d{4})-(\d{2})-(\d{2})/.exec(date);
      if (!m) return date;
      const d = new Date(`${m[1]}-${m[2]}-${m[3]}T00:00:00Z`);
      return `${date}-${WEEKDAYS[d.getUTCDay()]}`;
    }

    async function loadStats() {
      try {
        const res = await fetch('/api/stats');
        const data = await res.json();
        if (!data.ok) throw new Error(data.error);

        statsTotalsEl.innerHTML = `
          <div class="admin-stat-card"><div class="admin-stat-num">${data.totals.page || 0}</div><div class="admin-stat-label">网页总访问</div></div>
          <div class="admin-stat-card"><div class="admin-stat-num">${data.totals.api || 0}</div><div class="admin-stat-label">接口 / MCP 总调用</div></div>
        `;

        if (!data.daily || data.daily.length === 0) {
          statsDailyEl.innerHTML = '<p class="admin-hint">还没有按天的数据</p>';
          return;
        }
        // 标记全 0 的占位天（淡色），让预留的 7 行布局稳定又不喧宾夺主。
        const empty = data.daily.map((d: any) => (d.page || 0) === 0 && (d.api || 0) === 0);
        const col = (head: string, vals: string[]) =>
          `<div class="admin-daily-col"><div class="admin-daily-head">${head}</div>${vals
            .map((v, i) => `<div class="admin-daily-val${empty[i] ? ' is-empty' : ''}">${v}</div>`)
            .join('')}</div>`;
        statsDailyEl.innerHTML = `<div class="admin-daily-grid">
          ${col('日期', data.daily.map((d: any) => dateWithWeekday(d.date)))}
          ${col('网页访问', data.daily.map((d: any) => String(d.page || 0)))}
          ${col('接口 / MCP 调用', data.daily.map((d: any) => String(d.api || 0)))}
        </div>`;
      } catch (err) {
        statsTotalsEl.innerHTML = `<p class="admin-hint">统计加载失败：${err instanceof Error ? err.message : String(err)}</p>`;
      }
    }

    // 把一次运行映射成 {label, cls}：成功=绿、失败/取消=红、进行中/排队=主色脉动。
    function deployState(run: any): { label: string; cls: string } {
      if (run.status !== 'completed') {
        return { label: run.status === 'queued' ? '排队中' : '构建中', cls: 'running' };
      }
      if (run.conclusion === 'success') return { label: '成功', cls: 'ok' };
      if (run.conclusion === 'cancelled') return { label: '已取消', cls: 'err' };
      return { label: '失败', cls: 'err' };
    }

    function relativeTime(iso: string): string {
      const diff = Date.now() - new Date(iso).getTime();
      const min = Math.round(diff / 60000);
      if (min < 1) return '刚刚';
      if (min < 60) return `${min} 分钟前`;
      const hr = Math.round(min / 60);
      if (hr < 24) return `${hr} 小时前`;
      return `${Math.round(hr / 24)} 天前`;
    }

    async function loadDeploys() {
      try {
        const res = await fetch('/api/deploys');
        const data = await res.json();
        if (!data.ok) throw new Error(data.error);
        const runs = data.runs || [];
        if (runs.length === 0) {
          deploysEl.innerHTML = '<p class="admin-hint">还没有部署记录</p>';
          return;
        }
        const rows = runs
          .map((r: any) => {
            const s = deployState(r);
            return `
              <tr>
                <td><span class="admin-deploy-badge ${s.cls}"><span class="admin-deploy-dot"></span>${s.label}</span></td>
                <td>${escapeHtml(r.title)}</td>
                <td>${relativeTime(r.createdAt)}</td>
                <td class="admin-row-actions"><a class="admin-btn-link" href="${r.url}" target="_blank" rel="noopener">日志</a></td>
              </tr>`;
          })
          .join('');
        deploysEl.innerHTML = `
          <table>
            <thead><tr><th>状态</th><th>提交</th><th>时间</th><th></th></tr></thead>
            <tbody>${rows}</tbody>
          </table>`;
      } catch (err) {
        deploysEl.innerHTML = `<p class="admin-hint">部署状态加载失败：${err instanceof Error ? err.message : String(err)}</p>`;
      }
    }

    // 一次提交后 Actions 要几秒才登记到列表，先刷一次、再延迟刷一次，能看到新行冒出来。
    function refreshDeploysSoon() {
      loadDeploys();
      setTimeout(loadDeploys, 6000);
    }

    function setStatus(el: HTMLDivElement, ok: boolean, text: string) {
      el.textContent = `${ok ? '✅' : '❌'} ${text}`;
      el.className = `admin-status ${ok ? 'ok' : 'err'}`;
    }

    async function loadList() {
      listEl.innerHTML = '<p class="admin-hint">加载中…</p>';
      try {
        const res = await fetch('/index.json');
        const data = await res.json();
        const posts = data.posts || [];
        if (posts.length === 0) {
          listEl.innerHTML = '<p class="admin-hint">暂无文章</p>';
          return;
        }
        const table = document.createElement('table');
        table.innerHTML = `
          <thead><tr><th>日期</th><th>标题</th><th>标签</th><th></th></tr></thead>
          <tbody>
            ${posts
              .map(
                (p: any) => `
              <tr data-date="${p.date}">
                <td>${dateWithWeekday(p.date)}</td>
                <td>${escapeHtml(p.title)}</td>
                <td>${(p.tags || []).join(', ')}</td>
                <td class="admin-row-actions">
                  <button type="button" class="admin-btn-link" data-action="edit" data-date="${p.date}">编辑</button>
                  <button type="button" class="admin-btn-link admin-btn-danger" data-action="delete" data-date="${p.date}">删除</button>
                </td>
              </tr>`
              )
              .join('')}
          </tbody>`;
        listEl.innerHTML = '';
        listEl.appendChild(table);

        table.querySelectorAll('[data-action="edit"]').forEach((btn) => {
          btn.addEventListener('click', () => openEditor((btn as HTMLElement).dataset.date as string));
        });
        table.querySelectorAll('[data-action="delete"]').forEach((btn) => {
          btn.addEventListener('click', () => deleteArticle((btn as HTMLElement).dataset.date as string));
        });
      } catch (err) {
        listEl.innerHTML = `<p class="admin-hint">列表加载失败：${err instanceof Error ? err.message : String(err)}</p>`;
      }
    }

    function escapeHtml(s: string) {
      return s.replace(/[&<>"']/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c] as string));
    }

    // 把原始 .md 拆成 { frontmatter 对象, 正文 }。frontmatter 用 js-yaml 解析。
    function splitArticle(raw: string): { fm: Record<string, any>; body: string } {
      const t = raw.replace(/^﻿/, '');
      if (!t.startsWith('---')) return { fm: {}, body: t };
      const end = t.indexOf('\n---', 3);
      if (end === -1) return { fm: {}, body: t };
      const fmText = t.slice(3, end);
      const body = t.slice(end + 4).replace(/^\r?\n/, '');
      let fm: Record<string, any> = {};
      try {
        const parsed = yaml.load(fmText);
        if (parsed && typeof parsed === 'object') fm = parsed as Record<string, any>;
      } catch {
        /* 解析不了就当空，字段留空让用户重填，正文照常给出 */
      }
      return { fm, body };
    }

    // 从结构化字段重新拼出完整 .md。frontmatter 由 js-yaml 序列化，保证永远是合法 YAML，
    // 用户在标题/摘要里写任何引号都不会再把构建搞崩。
    function buildArticle(): string {
      const tags = fTags.value.split(/[,，]/).map((s) => s.trim()).filter(Boolean);
      const fm: Record<string, unknown> = {
        ...extraFrontmatter,
        date: editingDate,
        title: fTitle.value.trim(),
        summary: fSummary.value.trim(),
        tags,
      };
      const source = fSource.value.trim();
      if (source) fm.source = source;
      else delete fm.source;
      const fmText = yaml.dump(fm, { lineWidth: -1, forceQuotes: false }).trimEnd();
      return `---\n${fmText}\n---\n\n${editorTextarea.value.trim()}\n`;
    }

    // 轻量 Markdown 预览渲染器：覆盖本站文章用到的子集（## 标题 / 粗体 / 行内代码 /
    // 引用 / 列表 / 链接）。仅用于发布前自查排版，标签配色等站点效果以线上为准。
    function renderMarkdown(src: string): string {
      const inline = (s: string) =>
        escapeHtml(s)
          .replace(/`([^`]+)`/g, '<code>$1</code>')
          .replace(/\*\*([^*]+)\*\*/g, '<strong>$1</strong>')
          .replace(/\[([^\]]+)\]\(([^)\s]+)\)/g, '<a href="$2" target="_blank" rel="noopener">$1</a>');
      const lines = src.split('\n');
      const out: string[] = [];
      let para: string[] = [];
      let list: string[] = [];
      let quote: string[] = [];
      const flushPara = () => { if (para.length) { out.push(`<p>${inline(para.join(' '))}</p>`); para = []; } };
      const flushList = () => { if (list.length) { out.push(`<ul>${list.map((i) => `<li>${inline(i)}</li>`).join('')}</ul>`); list = []; } };
      const flushQuote = () => { if (quote.length) { out.push(`<blockquote>${inline(quote.join(' '))}</blockquote>`); quote = []; } };
      const flushAll = () => { flushPara(); flushList(); flushQuote(); };
      for (const line of lines) {
        const t = line.trim();
        const h = /^(#{1,4})\s+(.*)$/.exec(t);
        if (h) { flushAll(); const lv = h[1].length; out.push(`<h${lv}>${inline(h[2])}</h${lv}>`); continue; }
        if (t.startsWith('>')) { flushPara(); flushList(); quote.push(t.replace(/^>\s?/, '')); continue; }
        if (/^[-*]\s+/.test(t)) { flushPara(); flushQuote(); list.push(t.replace(/^[-*]\s+/, '')); continue; }
        if (t === '') { flushAll(); continue; }
        flushList(); flushQuote(); para.push(t);
      }
      flushAll();
      return out.join('\n');
    }

    function showEditMode() {
      previewEl.hidden = true;
      editorTextarea.hidden = false;
      previewToggle.textContent = '预览';
    }

    previewToggle.addEventListener('click', () => {
      if (previewEl.hidden) {
        previewEl.innerHTML = renderMarkdown(editorTextarea.value);
        previewEl.hidden = false;
        editorTextarea.hidden = true;
        previewToggle.textContent = '继续编辑';
      } else {
        showEditMode();
      }
    });

    async function openEditor(date: string) {
      editingDate = date;
      editorTitle.textContent = `❯ 编辑 ${dateWithWeekday(date)}`;
      editorStatus.textContent = '';
      editorStatus.className = 'admin-status';
      editorWrap.hidden = false;
      showEditMode();
      extraFrontmatter = {};
      fTitle.value = '';
      fSummary.value = '';
      fTags.value = '';
      fSource.value = '';
      editorTextarea.value = '加载中…';
      editorWrap.scrollIntoView({ behavior: 'smooth', block: 'start' });
      try {
        const res = await fetch(`/api/article?date=${date}`);
        const data = await res.json();
        if (!data.ok) throw new Error(data.error);
        const { fm, body } = splitArticle(data.content);
        // 已知字段填进输入框，其余未知字段存到 extraFrontmatter，保存时原样写回。
        const { date: _d, title, summary, tags, source, ...rest } = fm;
        extraFrontmatter = rest;
        fTitle.value = title ?? '';
        fSummary.value = summary ?? '';
        fTags.value = Array.isArray(tags) ? tags.join(', ') : (tags ?? '');
        fSource.value = source ?? '';
        editorTextarea.value = body;
      } catch (err) {
        editorTextarea.value = '';
        setStatus(editorStatus, false, `加载失败：${err instanceof Error ? err.message : String(err)}`);
      }
    }

    editorCancelBtn.addEventListener('click', () => {
      editorWrap.hidden = true;
      editingDate = null;
    });

    editorSaveBtn.addEventListener('click', async () => {
      if (!editingDate) return;
      if (!fTitle.value.trim() || !fSummary.value.trim()) {
        setStatus(editorStatus, false, '标题和摘要不能为空');
        return;
      }
      editorSaveBtn.disabled = true;
      setStatus(editorStatus, true, '保存中…');
      try {
        const blob = new Blob([buildArticle()], { type: 'text/markdown' });
        const file = new File([blob], `${editingDate}.md`, { type: 'text/markdown' });
        const formData = new FormData();
        formData.append('file', file);
        const res = await fetch('/api/publish', { method: 'POST', body: formData });
        const data = await res.json();
        if (!data.ok) throw new Error(data.error);
        setStatus(editorStatus, true, data.message);
        loadList();
        refreshDeploysSoon();
      } catch (err) {
        setStatus(editorStatus, false, err instanceof Error ? err.message : String(err));
      } finally {
        editorSaveBtn.disabled = false;
      }
    });

    async function deleteArticle(date: string) {
      if (!confirm(`确定删除 ${dateWithWeekday(date)} 这篇文章吗？此操作不可恢复。`)) return;
      try {
        const res = await fetch('/api/delete', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ date }),
        });
        const data = await res.json();
        if (!data.ok) throw new Error(data.error);
        setStatus(status, true, data.message);
        if (editingDate === date) {
          editorWrap.hidden = true;
          editingDate = null;
        }
        loadList();
        refreshDeploysSoon();
      } catch (err) {
        setStatus(status, false, err instanceof Error ? err.message : String(err));
      }
    }

    publishForm.addEventListener('submit', async (e) => {
      e.preventDefault();
      const file = fileInput.files?.[0];
      if (!file) return;

      submitBtn.disabled = true;
      status.textContent = '发布中…';
      status.className = 'admin-status';

      const formData = new FormData();
      formData.append('file', file);

      try {
        const res = await fetch('/api/publish', { method: 'POST', body: formData });
        const data = await res.json();
        if (data.ok) {
          setStatus(status, true, data.message);
          publishForm.reset();
          loadList();
          refreshDeploysSoon();
        } else {
          setStatus(status, false, data.error);
        }
      } catch (err) {
        setStatus(status, false, `网络错误：${err instanceof Error ? err.message : String(err)}`);
      } finally {
        submitBtn.disabled = false;
      }
    });

    loadList();
    loadStats();
    loadDeploys();
  </script>
</Layout>
