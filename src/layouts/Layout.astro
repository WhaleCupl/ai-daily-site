---
import '../styles/cli.css';

interface Props {
  title?: string;
  description?: string;
  /** og:type — 'website' for index/listing pages, 'article' for posts. */
  type?: 'website' | 'article';
  /** Absolute or root-relative URL of the social/share image. */
  image?: string;
  /** ISO date for article:published_time (article pages only). */
  publishedTime?: string;
  /** Schema.org JSON-LD object injected into <head>. */
  jsonLd?: Record<string, unknown>;
  /** Set true to keep this page out of search engines (e.g. /admin). */
  noindex?: boolean;
}

const {
  title = 'AI Daily Insights',
  description = 'AI Daily Insights — 每日 AI 资讯，为人与 Agent 而生',
  type = 'website',
  image,
  publishedTime,
  jsonLd,
  noindex = false,
} = Astro.props;

const SITE = 'https://www.aidailyinsights.cn';
// Canonical URL for this page (path only, normalized to the configured host).
const canonical = new URL(Astro.url.pathname, SITE).href;
const imageUrl = image ? new URL(image, SITE).href : undefined;
---

<!DOCTYPE html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <link rel="canonical" href={canonical} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="alternate" type="application/rss+xml" title="AI Daily Insights" href="/feed.xml" />
    <!-- 字体：JetBrains Mono（自托管，本地 woff2）。中文无字形，自动回退系统等宽中文 -->
    <link rel="preload" as="font" type="font/woff2" href="/fonts/jetbrains-mono/JetBrainsMono-Regular.woff2" crossorigin />

    <!-- Open Graph -->
    <meta property="og:type" content={type} />
    <meta property="og:site_name" content="AI Daily Insights" />
    <meta property="og:locale" content="zh_CN" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    {imageUrl && <meta property="og:image" content={imageUrl} />}
    {publishedTime && <meta property="article:published_time" content={publishedTime} />}

    <!-- Twitter Card -->
    <meta name="twitter:card" content={imageUrl ? 'summary_large_image' : 'summary'} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {imageUrl && <meta name="twitter:image" content={imageUrl} />}

    {jsonLd && (
      <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    )}
  </head>
  <body>
    <div class="term mono" id="term" data-theme="auto">
      <div class="window">
        <div class="titlebar">
          <div class="dots" aria-hidden="true"><span></span><span></span><span></span></div>
          <a class="path" href="/">~/ai-daily-insights</a>
          <nav class="topnav" aria-label="Primary">
            <a href="/">news</a>
            <a href="/qa/">q&a</a>
          </nav>
          <div class="theme-seg" role="group" aria-label="Theme">
            <button class="tbtn" type="button" data-theme-choice="light">light</button>
            <button class="tbtn" type="button" data-theme-choice="dark">dark</button>
            <button class="tbtn" type="button" data-theme-choice="auto">auto</button>
          </div>
        </div>
        <main class="stage">
          <slot />
        </main>
      </div>
      <footer class="term-footer">
        <div class="foot-prompt"><span class="fu">visitor@ai-daily</span>:<span class="fp">~</span>$ whoami<span class="cursor"></span></div>
        aidailyinsights.cn · 为人与 Agent 而生 · <a href="/qa/">Q&A</a> · <a href="/llms.txt">llms.txt</a>
      </footer>
    </div>
    <script>
      (function () {
        var KEY = "adi-theme", order = ["auto", "light", "dark"];
        var term = document.getElementById("term");
        var btns = Array.prototype.slice.call(document.querySelectorAll("[data-theme-choice]"));
        var t = localStorage.getItem(KEY) || "auto";
        function apply(v) {
          term.dataset.theme = v;
          btns.forEach(function (btn) {
            btn.setAttribute("aria-pressed", btn.dataset.themeChoice === v ? "true" : "false");
          });
        }
        apply(t);
        btns.forEach(function (btn) {
          btn.addEventListener("click", function () {
            t = btn.dataset.themeChoice || "auto";
            localStorage.setItem(KEY, t);
            apply(t);
          });
        });
      })();
    </script>
  </body>
</html>
